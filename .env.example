# vphone local secrets/config
#
# Copy this file to .env and edit it:
#   cp .env.example .env
#   chmod 600 .env
#
# .env is ignored by git and is loaded by:
#   - create_trollstore_instance.command
#   - launch_trollstore_vphone.command
#
# Priority: current shell environment > .env > vphone_instance.conf.
# Use shell syntax: KEY=value, no spaces around '='.

# Optional sudo password preload for fully unattended creation.
# WARNING: this stores your macOS admin password in plaintext.
# VPHONE_SUDO_PASSWORD="your-macOS-admin-password"

# Optional: disable interactive prompts when all required values are in env/config.
# VPHONE_INTERACTIVE_CONFIG=0

# Optional: setup_machine final boot-analysis is only a validation pass.
# One-click creation scripts skip it by default so they can hand off directly
# to launch_gui.command.
# SKIP_BOOT_ANALYSIS=1

# Optional: batch create multiple instances from create_trollstore_instance.command.
# VPHONE_CREATE_COUNT=3
# VPHONE_AUTO_LAUNCH_CREATED=0

# Optional: clone a stopped clean base instance instead of re-running restore.
# Used by clone_vphone_instance.command / scripts/clone_vphone_instance.sh.
# VPHONE_CLONE_SOURCE="/Users/true/Documents/vphone-cli/vm.instances/trollstore-clean-base"
# VPHONE_CLONE_COUNT=3
# VPHONE_CLONE_NAME=phone
# VPHONE_AUTO_LAUNCH_CLONED=1

# Optional: one-shot auto-install when launching an instance through
# scripts/launch_vphone_instance.sh. Usually prefer scripts/install_ipa_to_instance.sh.
# VPHONE_INSTALL_IPA="/Users/true/Downloads/App.ipa"
